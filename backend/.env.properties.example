# ===================================================================
# Backend Environment Configuration Template (.env.properties.example)
# Copy to backend/.env.properties
# ===================================================================

# Database (Local Docker PostgreSQL)
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_URL=jdbc:postgresql://localhost:5433/my_database
DB_DIRECT_URL=jdbc:postgresql://localhost:5433/my_database

# JWT Security Secrets & Expiration
JWT_SECRET=your_256bit_secret_key_here_at_least_32_characters
JWT_EXPIRATION_MS=7200000
JWT_REFRESH_EXPIRATION_MS=604800000

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_SECRET=your_google_client_secret

# AI Providers (Gemini & OpenAI Keys)
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
OPENAI_API_KEYS=your_openai_key_1

# OTP / SMS Configuration
SMS_API_KEY=
SMS_SENDER=ClassManager

# CORS & Application Settings
ALLOWED_ORIGINS=http://localhost:5173
APP_TIMEZONE=Asia/Ho_Chi_Minh
SPRING_PROFILES_ACTIVE=dev
