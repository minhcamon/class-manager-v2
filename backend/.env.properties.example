# Database (Supabase)
DB_PASSWORD=
DB_USERNAME=
DB_URL=jdbc:postgresql://<host>:6543/<db>?user=${DB_USERNAME}&password=${DB_PASSWORD}&pgbouncer=true&prepareThreshold=0
DB_DIRECT_URL=

# JWT
JWT_SECRET=
JWT_EXPIRATION_MS=7200000
JWT_REFRESH_EXPIRATION_MS=604800000
COOKIE_SECURE=false

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=
# OTP / SMS
SMS_API_KEY=
SMS_SENDER=ClassManager

# CORS
ALLOWED_ORIGINS=

# App
APP_TIMEZONE=Asia/Ho_Chi_Minh
SPRING_PROFILES_ACTIVE=dev
